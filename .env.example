# ─── STRIKER configuration ────────────────────────────────────────────────
# Copy to .env and fill in what you have. Everything has a safe default:
# with an empty .env STRIKER boots in SIM mode — real EIP-3009 signatures,
# real protocol verification, simulated on-chain settlement.

# "sim" (default) or "live". Live requires funded testnet wallets below.
STRIKER_MODE=sim

# ─── Wallets (Injective EVM testnet, chain 1439) ─────────────────────────
# Generate fresh ones with: npm run gen:wallets
# Fund with testnet INJ (gas) + USDC via https://testnet.faucet.injective.network
# AGENT_PRIVATE_KEY   — STRIKER's own wallet (buys data, receives earnings)
# FORGE_PRIVATE_KEY   — Data Forge facilitator wallet (receives data payments, pays gas)
AGENT_PRIVATE_KEY=
FORGE_PRIVATE_KEY=

# ─── AI brain ─────────────────────────────────────────────────────────────
# Optional. Without a key STRIKER uses its built-in deterministic analyst.
ANTHROPIC_API_KEY=
STRIKER_MODEL=claude-haiku-4-5-20251001

# ─── World Cup data ───────────────────────────────────────────────────────
# Optional. Free tier: https://www.football-data.org/client/register
# Without a token STRIKER runs REPLAY mode: a realistic simulated knockout
# slate that progresses in real time (clearly labeled in the UI).
FOOTBALL_DATA_TOKEN=
# Replay speed multiplier (15 = a 90' match plays out in 6 minutes)
REPLAY_SPEED=15

# ─── CCTP treasury (cross-chain USDC top-ups) ─────────────────────────────
# Reserve wallet on a CCTP source chain (e.g. Ethereum Sepolia) used to
# refill the agent when its Injective USDC drops below the floor.
CCTP_RESERVE_PRIVATE_KEY=
CCTP_SOURCE_RPC=https://ethereum-sepolia-rpc.publicnode.com
# CCTP v2 testnet contracts (uniform across EVM testnets — verify at
# https://developers.circle.com/cctp/evm-smart-contracts before live use)
CCTP_TOKEN_MESSENGER=0x8FE6B999Dc680CcFDD5Bf7EB0974218be2542DAA
CCTP_SOURCE_USDC=0x1c7D4B196Cb0C7B01d743Fbc6116a902379C7238
# Destination domain for Injective — 29 per Circle docs (verified 2026-07-04)
CCTP_DEST_DOMAIN=29
# Agent USDC floor / top-up amount, in USDC
TREASURY_FLOOR_USDC=2
TREASURY_TOPUP_USDC=5

# ─── Prediction stakes (STRIKER bets its own P&L on confident calls) ────────
# Enabled by default in sim mode. STRIKER locks STAKE_USDC when its favoured
# outcome clears STAKE_MIN_PROB, pays out at fair odds (stake / prob) at FT.
STAKE_ENABLED=true
STAKE_USDC=0.01
STAKE_MIN_PROB=0.55

# ─── Signal sheet scout (cross-match /api/signals buy) ────────────────────
# When 2+ matches are live STRIKER buys the 0.01 USDC signal sheet instead of
# spamming 0.02 deep calls — publishes from the highest-pressure match.
SIGNALS_ENABLED=true
SIGNALS_MIN_LIVE=2
SIGNALS_COOLDOWN_MS=120000
SIGNALS_PRESSURE_MIN=55

# ─── Ports ────────────────────────────────────────────────────────────────
FORGE_PORT=4021
AGENT_PORT=4042

# Healthy testnet RPC — the default k8s RPC serves stale transaction receipts
INJECTIVE_RPC_URL=https://testnet.sentry.chain.json-rpc.injective.network
